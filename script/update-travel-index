#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
cd "$repo_root"

python3 - <<'PY'
import json
from pathlib import Path

root = Path('assets/images/travels')
exts = {'.jpg', '.jpeg', '.png', '.webp'}
paths = sorted('/' + p.as_posix() for p in root.rglob('*') if p.is_file() and p.suffix.lower() in exts)
(root / 'index.json').write_text(json.dumps(paths, indent=2) + '\n', encoding='utf-8')
print(f'Updated {root / "index.json"} with {len(paths)} entries')
PY
